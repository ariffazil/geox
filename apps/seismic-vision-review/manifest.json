{
  "$schema": "https://geox.arif-fazil.com/schemas/app-manifest/v1.json",
  "app_id": "geox.seismic.vision.review",
  "version": "0.5.0-SCAFFOLD",
  "domain": "governance",
  "display_name": "Seismic Vision Review",
  "description": "Governed seismic interpretation surface with VLM integration and 7-day falsification probe",
  "icon": "https://geox.arif-fazil.com/apps/seismic_vision_review/icon.svg",
  "required_tools": [
    "mcp.geox.geox_seismic_vision_review_stub"
  ],
  "optional_tools": [
    "mcp.geox.compute_ac_risk",
    "mcp.geox.evaluate_ac_risk_governed",
    "mcp.geox.load_seismic_line"
  ],
  "ui_entry": {
    "resource_uri": "https://geox.arif-fazil.com/apps/seismic_vision_review/index.html",
    "mode": "inline-or-external",
    "capability_required": [
      "embedded_webview",
      "webgl"
    ],
    "csp_policy": "default-src 'self'; script-src 'self' 'unsafe-inline'; connect-src 'self' https://api.geox.arif-fazil.com; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:;",
    "sandbox": "allow-scripts allow-same-origin",
    "inline_config": {
      "max_width": 1400,
      "max_height": 900,
      "resize": true
    },
    "external_config": {
      "window_features": "width=1600,height=1000,menubar=no,toolbar=no"
    }
  },
  "auth": {
    "mode": "jwt",
    "token_ttl_seconds": 600,
    "scopes": [
      "tenant:{tenant_id}",
      "role:geoscientist|manager|viewer",
      "governance:read"
    ],
    "refreshable": true
  },
  "events": {
    "supported": [
      "app.initialize",
      "app.context.patch",
      "app.state.sync",
      "tool.request",
      "tool.result",
      "ui.action",
      "ui.state.change",
      "vision.fault_picked",
      "vision.gt_uploaded",
      "auth.challenge",
      "auth.result",
      "host.resize",
      "telemetry.emit"
    ],
    "max_payload_size": 1048576
  },
  "fallback": {
    "chain": [
      "inline",
      "external",
      "card",
      "text"
    ],
    "external_url": "https://geox.arif-fazil.com/apps/seismic_vision_review/?session={session_id}",
    "card_template": "/apps/seismic_vision_review/card.html"
  },
  "arifos": {
    "required_floors": [
      "F1",
      "F2",
      "F4",
      "F7",
      "F9",
      "F11",
      "F13"
    ],
    "audit_level": "full",
    "vault_route": "999_VAULT",
    "human_in_the_loop": [
      "commit_fault_picks",
      "launch_falsification_probe"
    ]
  },
  "meta": {
    "author": "GEOX Platform Team",
    "license": "MIT",
    "repository": "https://github.com/ariffazil/arifos-geox",
    "homepage": "https://geox.arif-fazil.com/apps/seismic_vision_review/",
    "keywords": [
      "seismic_vision",
      "vlm",
      "fault_interpretation",
      "falsification_probe",
      "governance"
    ],
    "created_at": "2026-04-13T00:00:00Z",
    "updated_at": "2026-04-13T00:00:00Z"
  }
}
