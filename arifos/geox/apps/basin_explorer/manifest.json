{
  "$schema": "https://geox.arif-fazil.com/schemas/app-manifest/v1.json",
  "app_id": "geox.basin.explorer",
  "version": "1.0.0-AAA",
  "domain": "maps",
  "display_name": "Basin Map Explorer",
  "description": "Basin-scale geological mapping with play fairway analysis — AAA Grade",
  "icon": "https://geox.arif-fazil.com/apps/basin_explorer/icon.svg",
  "required_tools": [
    "mcp.geox.query_memory",
    "mcp.geox.evaluate_prospect",
    "mcp.geox.verify_geospatial",
    "mcp.geox.malay_basin_pilot"
  ],
  "optional_tools": [
    "mcp.geox.query_macrostrat",
    "mcp.geox.load_seismic_line",
    "mcp.geox.earth_signals"
  ],
  "ui_entry": {
    "resource_uri": "https://geox.arif-fazil.com/apps/basin_explorer/index.html",
    "mode": "inline-or-external",
    "capability_required": [
      "webgl",
      "embedded_webview"
    ],
    "csp_policy": "default-src 'self'; script-src 'self' 'unsafe-inline' https://unpkg.com; connect-src 'self' https://api.geox.arif-fazil.com https://tile.openstreetmap.org https://*.basemaps.cartocdn.com; img-src 'self' data: https://*.basemaps.cartocdn.com; style-src 'self' 'unsafe-inline' https://unpkg.com;",
    "sandbox": "allow-scripts allow-same-origin allow-popups",
    "inline_config": {
      "max_width": 1400,
      "max_height": 900,
      "resize": true
    },
    "external_config": {
      "window_features": "width=1600,height=1000,menubar=no,toolbar=no"
    }
  },
  "auth": {
    "mode": "jwt",
    "token_ttl_seconds": 600,
    "scopes": [
      "tenant:{tenant_id}",
      "role:geoscientist|manager|viewer",
      "basin:read",
      "prospect:read",
      "well:read"
    ],
    "refreshable": true
  },
  "events": {
    "supported": [
      "app.initialize",
      "app.context.patch",
      "app.state.sync",
      "tool.request",
      "tool.result",
      "ui.action",
      "ui.state.change",
      "map.click",
      "map.select",
      "play.selected",
      "field.explore",
      "prospect.evaluate",
      "auth.challenge",
      "auth.result",
      "host.resize",
      "telemetry.emit"
    ],
    "max_payload_size": 1048576
  },
  "fallback": {
    "chain": [
      "inline",
      "external",
      "card",
      "text"
    ],
    "external_url": "https://geox.arif-fazil.com/apps/basin_explorer/?session={session_id}",
    "card_template": "/apps/basin_explorer/card.html"
  },
  "arifos": {
    "required_floors": [
      "F1",
      "F2",
      "F4",
      "F7",
      "F11"
    ],
    "audit_level": "standard",
    "vault_route": "999_VAULT",
    "human_in_the_loop": [
      "export_data",
      "prospect_book"
    ]
  },
  "meta": {
    "author": "GEOX Platform Team",
    "license": "MIT",
    "repository": "https://github.com/ariffazil/arifos-geox",
    "homepage": "https://geox.arif-fazil.com/apps/basin_explorer/",
    "keywords": [
      "basin",
      "maps",
      "play-fairway",
      "exploration",
      "malay-basin"
    ],
    "created_at": "2026-04-10T00:00:00Z",
    "updated_at": "2026-04-10T00:00:00Z"
  }
}
