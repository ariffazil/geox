// ── FAMILY DEFINITIONS ────────────────────────────────────────────────────────
const FAMILIES = {
    'ALL': { label: 'ALL 99' },
    'Sedimentary Clastic':         { label: 'Sedimentary Clastic 18' },
    'Sedimentary Carbonate':       { label: 'Sedimentary Carbonate 9' },
    'Sedimentary Chemical/Organic':{ label: 'Chemical    'Sedimentary Chemical/Organic':{ label: 'Chemical/Organic 9' },
    'Igneous Felsic':              { label: 'Igneous Felsic 9' },
    'Igneous Intermediate/Mafic':  { label: 'Igneous Mafic 9' },
    'Igneous Ultramafic/Altered':  { label: 'Igneous Ultramafic 9' },
    'Metamorphic Foliated':        { label: 'Metamorphic Foliated 9' },
    'Metamorphic Non-Foliated':    { label: 'Metamorphic Non-Foliated 9' },
    'Unconsolidated/Soil':        { label: 'Unconsolidated/Soil 9' },
    'Engineered Materials':        { label: 'Engineered Materials 9' },
};

// ── FAMILY COLORS ──────────────────────────────────────────────────────────────
const FAM_COLOR = {
    'Sedimentary Clastic':         '#c4791a',
    'Sedimentary Carbonate':       '#8b9eb5',
    'Sedimentary Chemical/Organic':'#b5542a',
    'Igneous Felsic':              '#d4a843',
    'Igneous Intermediate/Mafic':  '#4a9e8e',
    'Igneous Ultramafic/Altered':  '#3fb950',
    'Metamorphic Foliated':        '#bc8cff',
    'Metamorphic Non-Foliated':    '#9c8cff',
    'Unconsolidated/Soil':         '#7a6a52',
    'Engineered Materials':        '#f85149',
};

// ── STATE ─────────────────────────────────────────────────────────────────────
let activeFamily = 'ALL';
let searchQ = '';
let rhoF = '';
let rtF = '';
let nphiF = '';

// ── INIT ─────────────────────────────────────────────────────────────────────
function init() {
    // Build family chips
    const container = document.getElementById('familyChips');
    Object.entries(FAMILIES).forEach(([key, val]) => {
        const chip = document.createElement('div');
        chip.className = 'family-chip' + (key === 'ALL' ? ' active' : '');
        chip.dataset.family = key;
        chip.innerHTML = key.split(' ')[0] + ' ' + key.split(' ').slice(1).join(' ').split('/')[0] + ' <span class="count">' + MATERIALS.filter(m => key === 'ALL' || m.family === key).length + '</span>';
        chip.onclick = () => filterFamily(key);
        container.appendChild(chip);
    });

    buildTable();
}

function buildTable() {
    const tbody = document.getElementById('matTableBody');
    tbody.innerHTML = '';
    const filtered = MATERIALS.filter(m => {
        if (activeFamily !== 'ALL' && m.family !== activeFamily) return false;
        if (searchQ) {
            const q = searchQ.toLowerCase();
            if (!m.mat.toLowerCase().includes(q) && !m.sym.toLowerCase().includes(q) &&
                !m.family.toLowerCase().includes(q) && !m.notes.toLowerCase().includes(q) &&
                !m.id.toLowerCase().includes(q)) return false;
        }
        if (rhoF === 'light' && m.rho >= 2.5) return false;
        if (rhoF === 'mid' && (m.rho < 2.5 || m.rho >= 2.8)) return false;
        if (rhoF === 'dense' && m.rho < 2.8) return false;
        if (rtF === 'low' && m.rt >= 100) return false;
        if (rtF === 'mod' && (m.rt < 100 || m.rt >= 5000)) return false;
        if (rtF === 'high' && m.rt < 5000) return false;
        if (nphiF === 'neg' && m.nphi >= 0) return false;
        if (nphiF === 'low' && (m.nphi < 0 || m.nphi > 0.10)) return false;
        if (nphiF === 'high' && m.nphi <= 0.10) return false;
        return true;
    });

    document.getElementById('visibleCount').textContent = filtered.length;

    filtered.forEach(m => {
        const tr = document.createElement('div');
        tr.className = 'table-row';
        const nphiStr = m.nphi < 0 ? m.nphi.toFixed(2) : '+' + m.nphi.toFixed(2);
        const rtStr = m.rt >= 1000 ? (m.rt/1000).toFixed(0) + 'k' : String(m.rt);
        const color = FAM_COLOR[m.family] || '#8b949e';
        tr.innerHTML = `
            <div class="td id">${m.id}</div>
            <div class="td sym">${m.sym}</div>
            <div class="td mat">${m.mat}</div>
            <div class="td rho">${m.rho.toFixed(2)}</div>
            <div class="td nphi">${nphiStr}</div>
            <div class="td gr">${m.gr}</div>
            <div class="td rt">${rtStr}</div>
            <div class="td notes">${m.notes}</div>
        `;
        tbody.appendChild(tr);
    });
}

function filterFamily(fam) {
    activeFamily = fam;
    document.querySelectorAll('.family-chip').forEach(c => {
        c.classList.toggle('active', c.dataset.family === fam);
    });
    buildTable();
}

function filterAll() {
    searchQ = document.getElementById('searchInput').value;
    rhoF = document.getElementById('rhoFilter').value;
    rtF = document.getElementById('rtFilter').value;
    nphiF = document.getElementById('nphiFilter').value;
    buildTable();
}

function showTab(tab) {
    document.querySelectorAll('.nav-tab').forEach(b => b.classList.toggle('active', b.textContent.toLowerCase() === tab));
    document.getElementById('tab-atlas').style.display = tab === 'atlas' ? 'block' : 'none';
    document.getElementById('tab-physics').style.display = tab === 'physics' ? 'block' : 'none';
    document.getElementById('tab-symbolic').style.display = tab === 'symbolic' ? 'block' : 'none';
    document.getElementById('tab-context').style.display = tab === 'context' ? 'block' : 'none';
}

init();
</script>
