<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>RATLAS v0.1 · GEOX Reference Atlas of Earth Materials</title>
<link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 32 32'><rect width='32' height='32' fill='%230d0d0d' rx='4'/><text x='16' y='22' font-size='18' text-anchor='middle' fill='%23ff6b35'>τ</text></svg>">
<style>
:root {
    --bg-deep: #080c10; --bg-surface: #0d1117; --bg-card: #131a24;
    --bg-hover: #1a2332; --border: #1e2d3d; --border-bright: #2d4a5e;
    --text-primary: #e6edf3; --text-secondary: #8b949e; --text-muted: #484f58;
    --accent: #ff6b35; --accent-dim: rgba(255,107,53,0.15); --accent-glow: rgba(255,107,53,0.4);
    --cyan: #39c5bb; --cyan-dim: rgba(57,197,187,0.15);
    --green: #3fb950; --amber: #d29922; --red: #f85149; --purple: #bc8cff;
}
* { margin: 0; padding: 0; box-sizing: border-box; }
body {
    background: var(--bg-deep); color: var(--text-primary);
    font-family: 'Courier New', Courier, monospace; font-size: 13px; line-height: 1.6;
    min-height: 100vh;
}

/* HEADER */
header {
    border-bottom: 1px solid var(--border);
    position: sticky; top: 0; z-index: 100; background: var(--bg-deep);
}
.header-inner {
    max-width: 1400px; margin: 0 auto; padding: 12px 24px;
    display: flex; align-items: center; gap: 20px; flex-wrap: wrap;
}
.logo {
    font-size: 18px; font-weight: bold; color: var(--accent);
    letter-spacing: 2px; text-shadow: 0 0 20px var(--accent-glow); white-space: nowrap;
}
.logo span { color: var(--text-secondary); font-weight: normal; }
.badges { display: flex; gap: 6px; flex-wrap: wrap; }
.badge { font-size: 9px; padding: 2px 7px; border-radius: 3px; font-weight: bold; letter-spacing: 1px; }
.badge-f1 { background: rgba(57,197,187,0.2); color: var(--cyan); border: 1px solid var(--cyan); }
.badge-f2 { background: rgba(255,107,53,0.2); color: var(--accent); border: 1px solid var(--accent); }
.badge-f4 { background: rgba(255,255,255,0.1); color: var(--text-secondary); border: 1px solid var(--border); }
.badge-f7 { background: rgba(210,153,34,0.2); color: var(--amber); border: 1px solid var(--amber); }
.badge-f9 { background: rgba(188,140,255,0.2); color: var(--purple); border: 1px solid var(--purple); }
.badge-f13 { background: rgba(63,185,80,0.2); color: var(--green); border: 1px solid var(--green); }
.badge-hold { background: rgba(248,81,73,0.2); color: var(--red); border: 1px solid var(--red); }
.header-right { margin-left: auto; display: flex; align-items: center; gap: 8px; }
.tagline { font-size: 10px; color: var(--text-muted); letter-spacing: 1px; }

/* MAIN */
main { max-width: 1400px; margin: 0 auto; padding: 20px 24px; }

/* HERO SCHEMATIC */
.hero {
    border: 1px solid var(--border); background: var(--bg-surface);
    border-radius: 4px; padding: 16px 20px; margin-bottom: 20px;
}
.hero-title { font-size: 10px; color: var(--text-muted); letter-spacing: 2px; margin-bottom: 12px; text-transform: uppercase; }
.schematic {
    display: grid;
    grid-template-columns: 130px repeat(6, 1fr);
    gap: 2px; font-size: 9px; overflow-x: auto;
}
.sch-header { color: var(--text-muted); text-align: center; padding: 5px 4px; letter-spacing: 1px; border-bottom: 1px solid var(--border); }
.sch-lit { display: flex; align-items: center; gap: 6px; padding: 5px 8px; color: var(--text-secondary); font-size: 9px; border-right: 1px solid var(--border); }
.sch-lit .dot { width: 7px; height: 7px; border-radius: 50%; flex-shrink: 0; }
.sch-cell { padding: 4px 3px; text-align: center; color: var(--text-muted); font-size: 8px; border: 1px solid var(--border); min-height: 24px; display: flex; align-items: center; justify-content: center; }
.sch-cell.gr { background: rgba(255,107,53,0.05); }
.sch-cell.cal { background: rgba(57,197,187,0.05); }
.sch-cell.den { background: rgba(210,153,34,0.05); }
.sch-cell.neu { background: rgba(57,197,187,0.08); }
.sch-cell.dt  { background: rgba(255,255,255,0.03); }
.sch-cell.rt  { background: rgba(248,81,73,0.05); }

/* SECTION TITLES */
.section-title { font-size: 10px; color: var(--text-muted); letter-spacing: 2px; text-transform: uppercase; margin-bottom: 10px; padding-bottom: 6px; border-bottom: 1px solid var(--border); }

/* FAMILY CHIPS */
.family-row { display: flex; flex-wrap: wrap; gap: 6px; margin-bottom: 16px; }
.family-chip {
    padding: 6px 12px; background: var(--bg-card); border: 1px solid var(--border);
    border-radius: 3px; cursor: pointer; transition: all 0.15s; font-size: 10px;
    display: flex; align-items: center; gap: 6px;
}
.family-chip:hover { border-color: var(--accent); background: var(--accent-dim); }
.family-chip.active { border-color: var(--accent); background: var(--accent-dim); }
.family-chip .count { background: var(--bg-deep); color: var(--text-muted); padding: 1px 5px; border-radius: 2px; font-size: 9px; }
.family-chip.active .count { background: var(--accent); color: var(--bg-deep); }

/* SEARCH */
.search-row { display: flex; gap: 8px; margin-bottom: 12px; flex-wrap: wrap; }
.search-input {
    flex: 1; min-width: 200px; background: var(--bg-card); border: 1px solid var(--border);
    color: var(--text-primary); padding: 7px 12px; font-family: inherit; font-size: 11px;
    border-radius: 3px; outline: none; transition: border-color 0.2s;
}
.search-input:focus { border-color: var(--accent); }
.search-input::placeholder { color: var(--text-muted); }
.filter-select {
    background: var(--bg-card); border: 1px solid var(--border); color: var(--text-primary);
    padding: 7px 10px; font-family: inherit; font-size: 10px; border-radius: 3px;
    cursor: pointer; outline: none;
}
.filter-select:focus { border-color: var(--accent); }

/* TABLE */
.count-bar { display: flex; justify-content: space-between; align-items: center; margin-bottom: 6px; font-size: 10px; color: var(--text-muted); }
.count-bar strong { color: var(--accent); }
.table-wrap { border: 1px solid var(--border); border-radius: 4px; overflow: hidden; margin-bottom: 20px; }
.table-header {
    display: grid;
    grid-template-columns: 90px 120px 1fr 80px 75px 70px 90px 220px;
    background: var(--bg-card); border-bottom: 1px solid var(--border);
    font-size: 9px; color: var(--text-muted); letter-spacing: 1px;
}
.th { padding: 7px 8px; }
.table-body { max-height: 480px; overflow-y: auto; }
.table-row {
    display: grid;
    grid-template-columns: 90px 120px 1fr 80px 75px 70px 90px 220px;
    border-bottom: 1px solid var(--border); font-size: 10px; transition: background 0.1s;
}
.table-row:hover { background: var(--bg-hover); }
.table-row.hidden { display: none; }
.td { padding: 6px 8px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.td.id { color: var(--text-muted); font-size: 9px; }
.td.sym { font-family: 'Courier New', monospace; color: var(--accent); font-size: 9px; }
.td.mat { color: var(--text-primary); }
.td.rho { color: var(--amber); text-align: right; }
.td.nphi { color: var(--cyan); text-align: right; }
.td.gr { color: var(--accent); text-align: right; }
.td.rt { color: var(--green); text-align: right; }
.td.notes { color: var(--text-muted); font-size: 9px; }

/* PHYSICS CARDS */
.physics-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; margin-bottom: 20px; }
.phys-card { background: var(--bg-surface); border: 1px solid var(--border); border-radius: 4px; padding: 14px; }
.phys-title { font-size: 10px; color: var(--accent); letter-spacing: 2px; margin-bottom: 10px; text-transform: uppercase; }
.equation { background: var(--bg-deep); border: 1px solid var(--border); padding: 10px 14px; margin: 6px 0; border-radius: 3px; font-size: 11px; color: var(--text-primary); overflow-x: auto; }
.eq-label { font-size: 9px; color: var(--text-muted); margin-bottom: 3px; }
.eq-vars { margin-top: 8px; font-size: 9px; color: var(--text-muted); }
.eq-vars span { color: var(--cyan); margin-right: 10px; }

/* SYMBOLIC */
.symbolic-section { background: var(--bg-surface); border: 1px solid var(--border); border-radius: 4px; padding: 14px; margin-bottom: 20px; }
.symbol-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr)); gap: 6px; margin-top: 10px; }
.symbol-item { display: flex; align-items: center; gap: 10px; padding: 6px 10px; background: var(--bg-deep); border: 1px solid var(--border); border-radius: 3px; font-size: 10px; }
.symbol-item .code { font-family: 'Courier New', monospace; color: var(--accent); min-width: 140px; font-size: 10px; }
.symbol-item .desc { color: var(--text-secondary); font-size: 9px; }

/* CONTEXT CARDS */
.ctx-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: 10px; margin-bottom: 20px; }
.ctx-card { background: var(--bg-card); border: 1px solid var(--border); border-radius: 4px; padding: 12px; text-decoration: none; color: var(--text-primary); transition: all 0.15s; display: block; }
.ctx-card:hover { border-color: var(--accent); background: var(--accent-dim); }
.ctx-label { font-size: 9px; color: var(--text-muted); letter-spacing: 1px; margin-bottom: 4px; }
.ctx-title { font-size: 11px; color: var(--accent); margin-bottom: 3px; }
.ctx-url { font-size: 9px; color: var(--text-muted); word-break: break-all; }

/* NAV TABS */
.nav-tabs { display: flex; gap: 0; margin-bottom: 16px; border-bottom: 1px solid var(--border); }
.nav-tab {
    padding: 8px 16px; background: transparent; border: none; border-bottom: 2px solid transparent;
    color: var(--text-secondary); font-family: inherit; font-size: 10px; cursor: pointer;
    letter-spacing: 1px; transition: all 0.15s;
}
.nav-tab:hover { color: var(--text-primary); }
.nav-tab.active { border-bottom-color: var(--accent); color: var(--accent); }

/* SCROLLBAR */
::-webkit-scrollbar { width: 5px; height: 5px; }
::-webkit-scrollbar-track { background: var(--bg-deep); }
::-webkit-scrollbar-thumb { background: var(--border-bright); border-radius: 3px; }
::-webkit-scrollbar-thumb:hover { background: var(--text-muted); }

/* RESPONSIVE */
@media (max-width: 768px) {
    .physics-grid { grid-template-columns: 1fr; }
    .table-header, .table-row { grid-template-columns: 70px 100px 1fr 65px 60px 55px 75px 160px; }
    .schematic { grid-template-columns: 100px repeat(6, 1fr); }
}
</style>
</head>
