{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://geox.arif-fazil.com/schemas/app-manifest/v1.json",
  "title": "GEOX App Manifest",
  "description": "Canonical manifest schema for GEOX MCP Apps. Host-agnostic definition of app capabilities, requirements, and integration contracts.",
  "type": "object",
  "required": ["app_id", "version", "domain", "ui_entry", "auth"],
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "type": "string",
      "description": "JSON Schema reference"
    },
    "app_id": {
      "type": "string",
      "pattern": "^geox\\.[a-z][a-z0-9-]*\\.[a-z][a-z0-9-]*$",
      "description": "Unique app identifier in geox.{domain}.{name} format"
    },
    "version": {
      "type": "string",
      "pattern": "^(0|[1-9]\\d*)\\.(0|[1-9]\\d*)\\.(0|[1-9]\\d*)(?:-([a-zA-Z0-9-]+(?:\\.[a-zA-Z0-9-]+)*))?(?:\\+([a-zA-Z0-9-]+(?:\\.[a-zA-Z0-9-]+)*))?$",
      "description": "Semantic version (semver)"
    },
    "domain": {
      "type": "string",
      "enum": [
        "seismic",
        "petrophysics",
        "geology",
        "maps",
        "wells",
        "docs",
        "economics",
        "general"
      ],
      "description": "Functional domain for organization and permissions"
    },
    "display_name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 64,
      "description": "Human-readable app name"
    },
    "description": {
      "type": "string",
      "maxLength": 256,
      "description": "Short description of app purpose"
    },
    "icon": {
      "type": "string",
      "format": "uri",
      "description": "App icon URL (SVG preferred)"
    },
    "required_tools": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^mcp\\.geox\\.[a-z0-9_\\.\\*]+$"
      },
      "description": "Required MCP tools (may use wildcards)"
    },
    "optional_tools": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^mcp\\.geox\\.[a-z0-9_\\.\\*]+$"
      },
      "description": "Optional MCP tools for enhanced functionality"
    },
    "ui_entry": {
      "type": "object",
      "required": ["resource_uri", "mode"],
      "properties": {
        "resource_uri": {
          "type": "string",
          "format": "uri",
          "description": "Primary entry point URL for the app"
        },
        "mode": {
          "type": "string",
          "enum": ["inline", "external", "inline-or-external"],
          "description": "Preferred rendering mode"
        },
        "capability_required": {
          "type": "array",
          "items": {
            "enum": [
              "embedded_webview",
              "webgl",
              "webgl2",
              "wasm",
              "webrtc",
              "file_system",
              "notifications"
            ]
          },
          "description": "Browser capabilities required"
        },
        "csp_policy": {
          "type": "string",
          "description": "Content Security Policy for the app"
        },
        "sandbox": {
          "type": "string",
          "default": "allow-scripts allow-same-origin",
          "description": "Iframe sandbox attributes"
        },
        "inline_config": {
          "type": "object",
          "description": "Configuration for inline mode",
          "properties": {
            "max_width": { "type": "integer", "default": 1200 },
            "max_height": { "type": "integer", "default": 800 },
            "resize": { "type": "boolean", "default": true }
          }
        },
        "external_config": {
          "type": "object",
          "description": "Configuration for external mode",
          "properties": {
            "window_features": {
              "type": "string",
              "default": "width=1400,height=900,menubar=no,toolbar=no"
            }
          }
        }
      }
    },
    "auth": {
      "type": "object",
      "required": ["mode"],
      "properties": {
        "mode": {
          "type": "string",
          "enum": ["jwt", "session", "none"],
          "description": "Authentication mode"
        },
        "token_ttl_seconds": {
          "type": "integer",
          "default": 300,
          "minimum": 60,
          "maximum": 3600,
          "description": "Token time-to-live"
        },
        "scopes": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^(tenant|role|dataset|well|basin|survey):.+$"
          },
          "description": "Required permission scopes"
        },
        "refreshable": {
          "type": "boolean",
          "default": true,
          "description": "Whether tokens can be refreshed"
        }
      }
    },
    "events": {
      "type": "object",
      "required": ["supported"],
      "properties": {
        "supported": {
          "type": "array",
          "items": {
            "enum": [
              "app.initialize",
              "app.context.patch",
              "app.state.sync",
              "tool.request",
              "tool.result",
              "tool.progress",
              "ui.action",
              "ui.state.change",
              "ui.error",
              "auth.challenge",
              "auth.result",
              "auth.refresh",
              "host.capability.report",
              "host.resize",
              "host.focus",
              "host.open.external",
              "host.close",
              "telemetry.emit",
              "telemetry.flush"
            ]
          },
          "description": "Events this app can send/receive"
        },
        "max_payload_size": {
          "type": "integer",
          "default": 1048576,
          "description": "Maximum event payload size in bytes"
        }
      }
    },
    "fallback": {
      "type": "object",
      "required": ["chain"],
      "properties": {
        "chain": {
          "type": "array",
          "items": {
            "enum": ["inline", "external", "card", "text", "link"]
          },
          "description": "Degradation chain in order of preference"
        },
        "external_url": {
          "type": "string",
          "format": "uri",
          "description": "External fallback URL template"
        },
        "card_template": {
          "type": "string",
          "description": "Path to card renderer template"
        }
      }
    },
    "arifos": {
      "type": "object",
      "description": "arifOS constitutional governance configuration",
      "properties": {
        "required_floors": {
          "type": "array",
          "items": {
            "enum": [
              "F1", "F2", "F3", "F4", "F5", "F6", "F7",
              "F8", "F9", "F10", "F11", "F12", "F13"
            ]
          },
          "default": ["F1", "F2", "F4", "F7", "F11"]
        },
        "audit_level": {
          "type": "string",
          "enum": ["minimal", "standard", "full"],
          "default": "standard"
        },
        "vault_route": {
          "type": "string",
          "default": "999_VAULT"
        },
        "human_in_the_loop": {
          "type": "array",
          "items": {
            "enum": [
              " destructive_operations",
              "export_data",
              "modify_production",
              "high_confidence_threshold"
            ]
          },
          "description": "Operations requiring 888_HOLD"
        }
      }
    },
    "meta": {
      "type": "object",
      "properties": {
        "author": { "type": "string" },
        "license": { "type": "string" },
        "repository": { "type": "string", "format": "uri" },
        "homepage": { "type": "string", "format": "uri" },
        "keywords": {
          "type": "array",
          "items": { "type": "string" }
        },
        "created_at": {
          "type": "string",
          "format": "date-time"
        },
        "updated_at": {
          "type": "string",
          "format": "date-time"
        }
      }
    }
  }
}
