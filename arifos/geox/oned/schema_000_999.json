{
  "schema_version": "1.0-SEALED",
  "schema_name": "GEOX_1D_000_999",
  "description": "1D GEOX column workflow mapped to arifOS 000-999 metabolic loop",
  "motto": "DITEMPA BUKAN DIBERI",
  
  "pipeline": {
    "000_INIT_ANCHOR": {
      "stage": 0,
      "name": "INIT",
      "purpose": "Verify authority, dataset scope, safety boundaries",
      "inputs": {
        "well_id": "string - unique well identifier",
        "authority_token": "string - who authorized this run",
        "dataset_manifest": {
          "las_file": "path - log data",
          "seismic_trace": "path - extracted trace at well",
          "checkshot": "path - time-depth relationship",
          "core_data": "optional path - calibration data"
        },
        "scope_boundary": {
          "depth_range": "[z_top, z_base] in meters",
          "canon9_channels_mutable": ["porosity", "sw", "density", "vp", "vs"],
          "canon9_channels_fixed": ["pressure", "temperature", "resistivity"]
        }
      },
      "outputs": {
        "run_id": "uuid - unique run identifier",
        "anchor_status": "ANCHORED | HOLD",
        "hold_reason": "string if HOLD"
      },
      "floor_checks": ["F1_Amanah", "F13_Sovereign"]
    },
    
    "111_THINK_SENSE": {
      "stage": 111,
      "name": "THINK",
      "purpose": "Classify intent and select operators",
      "inputs": {
        "intent_classification": {
          "type": "enum",
          "values": ["forward_only", "inverse_update", "joint_calibration", "sensitivity_analysis"]
        },
        "operator_selection": {
          "rock_physics_model": "Gassmann | Biot | HashinShtrikman",
          "reflectivity_method": "Zoeppritz | AkiRichards | Shuey",
          "wavelet_type": "Ricker | Ormsby | extracted",
          "inversion_engine": "gradient_descent | monte_carlo | neural_surrogate"
        }
      },
      "outputs": {
        "operator_manifest": "list of selected operators with version hashes",
        "execution_plan": "ordered steps for forward/inverse chain"
      },
      "floor_checks": ["F4_Clarity"]
    },
    
    "222_REASON": {
      "stage": 222,
      "name": "REASON",
      "purpose": "Propose hypotheses for x(z) - priors from geology",
      "inputs": {
        "geological_priors": {
          "expected_lithology": "shale | sand | carbonate | mixed",
          "facies_model": "optional - facies probabilities vs depth",
          "analog_wells": ["list of well_ids with similar geology"],
          "depositional_environment": "fluvial | deltaic | deepwater | carbonate_platform"
        },
        "initial_canon9": {
          "source": "uniform_guess | analog_transfer | previous_inversion",
          "profile": "Canon9Profile - initial x(z)"
        }
      },
      "outputs": {
        "hypothesis_set": "prior distribution over x(z)",
        "expected_ranges": {
          "porosity": "[phi_min, phi_max]",
          "sw": "[sw_min, sw_max]",
          "vp": "[vp_min, vp_max]"
        }
      },
      "floor_checks": ["F7_Humility"]
    },
    
    "333_EXPLORE_INTEGRATE": {
      "stage": 333,
      "name": "EXPLORE",
      "purpose": "Run forward F(x) → d̂, compare to observations",
      "inputs": {
        "current_canon9": "Canon9Profile - current x(z) estimate",
        "forward_operators": {
          "rock_physics": "GassmannModel.forward()",
          "reflectivity": "ZoeppritzModel.compute_reflectivity()",
          "synthetic": "SyntheticSeismic.generate()",
          "log_forward": "ToolPhysics.predict()"
        }
      },
      "operators": {
        "F_rock_physics": {
          "description": "{φ, P, T, fluids} → {ρ, Vp, Vs}",
          "inputs": ["porosity", "pressure", "temperature", "sw", "mineral_mix"],
          "outputs": ["density", "vp", "vs"],
          "physics": "Gassmann/Biot equations"
        },
        "F_reflectivity": {
          "description": "Elastic contrasts → R(θ,z)",
          "inputs": ["rho1", "vp1", "vs1", "rho2", "vp2", "vs2", "angle"],
          "outputs": ["reflection_coefficient"],
          "physics": "Zoeppritz equations or Aki-Richards approximation"
        },
        "F_synthetic": {
          "description": "Reflectivity → synthetic seismic",
          "inputs": ["reflectivity", "wavelet", "time_depth_curve"],
          "outputs": ["synthetic_trace"],
          "physics": "Convolution: trace = wavelet * reflectivity"
        },
        "F_log_forward": {
          "description": "CANON_9 → synthetic tool responses",
          "inputs": ["canon9_state", "tool_geometry", "environmental_params"],
          "outputs": ["synthetic_gr", "synthetic_density", "synthetic_resistivity"],
          "physics": "Tool physics + environmental corrections"
        }
      },
      "outputs": {
        "synthetic_data": {
          "seismic_cmp": "SyntheticCMP - traces at multiple angles",
          "synthetic_logs": "dict - predicted log curves"
        },
        "misfit_preview": {
          "seismic_correlation": "correlation coefficient",
          "log_misfit": "L2 norm per log type",
          "gross_mismatch_flag": "bool - major discrepancy detected"
        }
      },
      "floor_checks": ["F2_Truth", "F9_AntiHantu"]
    },
    
    "444_RESPOND": {
      "stage": 444,
      "name": "RESPOND",
      "purpose": "Draft candidate update plan for inversion",
      "inputs": {
        "misfit_analysis": "from 333",
        "parameter_sensitivity": "∂F/∂x for each parameter",
        "update_strategy": {
          "parameters_to_invert": ["porosity", "sw"],
          "fixed_parameters": ["pressure", "temperature"],
          "regularization": {
            "smoothness_weight": 0.1,
            "rock_physics_prior_weight": 0.5,
            "bounds": {
              "porosity": [0, 0.5],
              "sw": [0, 1]
            }
          }
        }
      },
      "outputs": {
        "update_plan": {
          "method": "gradient_descent | mcmc | variational",
          "max_iterations": 100,
          "convergence_tolerance": 1e-6,
          "step_size": 0.01
        }
      },
      "floor_checks": ["F3_TriWitness"]
    },
    
    "555_VALIDATE": {
      "stage": 555,
      "name": "VALIDATE",
      "purpose": "Check impact - geological plausibility, safety",
      "inputs": {
        "proposed_update": "delta_x - changes to canon9",
        "impact_assessment": {
          "geological_plausibility": "within expected ranges?",
          "measurement_consistency": "within log error bars?",
          "downstream_impact": "affects reserves estimate? CO2 capacity?"
        }
      },
      "outputs": {
        "validation_status": "VALIDATED | QUALIFIED | HOLD",
        "validation_notes": "explanation of concerns if not VALIDATED"
      },
      "floor_checks": ["F5_Peace", "F6_Maruah"]
    },
    
    "666_ALIGN": {
      "stage": 666,
      "name": "ALIGN",
      "purpose": "Ethics/safety - regulatory constraints, uncertainty disclosure",
      "inputs": {
        "proposed_result": "x*(z) from inversion",
        "uncertainty_envelope": "posterior std per parameter",
        "regulatory_constraints": {
          "reserves_reporting": "SEC/SPE compliance required?",
          "co2_storage": "CO2 capacity estimate affected?",
          "environmental": "impact on protected areas?"
        }
      },
      "outputs": {
        "alignment_status": "ALIGNED | FLAGGED",
        "flags": ["list of ethical/safety concerns"],
        "uncertainty_disclosure": "mandatory uncertainty statements"
      },
      "floor_checks": ["F6_Maruah", "F11_Auditability"]
    },
    
    "777_FORGE": {
      "stage": 777,
      "name": "FORGE",
      "purpose": "Execute inversion loop numerically",
      "inputs": {
        "initial_guess": "Canon9Profile - x₀(z)",
        "observed_data": {
          "seismic": "SyntheticCMP - observed traces",
          "logs": "dict - observed log curves"
        },
        "objective_function": "J(x) = ||d_obs - F(x)||² + α||x - x_prior||²"
      },
      "operator": {
        "inversion_engine": {
          "type": "JointInversion1D",
          "method": "gradient_descent | mcmc | neural_surrogate",
          "description": "Optimize J(x) to find x*(z)"
        }
      },
      "outputs": {
        "result": {
          "posterior_canon9": "Canon9Profile - x*(z)",
          "misfit_history": "list - J(x) vs iteration",
          "convergence_status": "CONVERGED | MAX_ITER | DIVERGED",
          "posterior_uncertainty": {
            "porosity_std": "array - std dev vs depth",
            "sw_std": "array - std dev vs depth"
          }
        }
      },
      "floor_checks": ["F7_Humility"]
    },
    
    "888_AUDIT": {
      "stage": 888,
      "name": "AUDIT",
      "purpose": "Tri-witness cross-check",
      "inputs": {
        "inversion_result": "from 777",
        "witness_evidence": {
          "human_geoscientist": "expert review of result",
          "geox_physics": "residuals within physical bounds?",
          "external_data": "production data, core measurements"
        }
      },
      "witnesses": {
        "W1_Human": {
          "role": "expert geoscientist review",
          "check": "geological plausibility"
        },
        "W2_GEOX_Physics": {
          "role": "physics consistency check",
          "check": "rock physics residuals, velocity-porosity relationships"
        },
        "W3_External_Data": {
          "role": "ground truth comparison",
          "check": "core porosity, MDT pressures, production rates"
        }
      },
      "outputs": {
        "audit_result": {
          "status": "PASS | QUALIFIED | HOLD",
          "witness_agreement": "W1∩W2∩W3 confidence",
          "residuals": {
            "seismic_residual": "observed - synthetic",
            "log_residuals": "per log type"
          },
          "hold_triggers": ["any 888_HOLD conditions"]
        }
      },
      "floor_checks": ["F3_TriWitness", "F8_Genius"]
    },
    
    "999_SEAL": {
      "stage": 999,
      "name": "SEAL",
      "purpose": "Commit to VAULT999 as current best 1D state",
      "inputs": {
        "audited_result": "from 888",
        "metadata": {
          "priors": "initial guess and geological assumptions",
          "operators": "versioned operator manifest",
          "residuals": "final misfit values",
          "uncertainty": "posterior covariance"
        }
      },
      "seal_contents": {
        "canon9_profile": "Canon9Profile - sealed x*(z)",
        "operator_chain": "exact operators and parameters used",
        "input_data_hashes": "hashes of all input datasets",
        "residuals": "final data misfits",
        "uncertainty_envelope": "confidence intervals per parameter",
        "audit_trail": "888_AUDIT results and signatures",
        "timestamp": "ISO 8601 timestamp",
        "seal_signature": "cryptographic hash of above"
      },
      "outputs": {
        "seal_id": "uuid - unique seal identifier",
        "vault_path": "VAULT999 storage location",
        "seal_status": "SEALED | REJECTED",
        "telemetry": "[GEOX-1D-SEAL | well_id | seal_id | floors | DITEMPA BUKAN DIBERI]"
      },
      "floor_checks": ["F1_Amanah", "F11_Auditability", "F13_Sovereign"]
    }
  },
  
  "data_types": {
    "Canon9Profile": {
      "description": "1D vertical column of CANON_9 samples",
      "fields": {
        "well_id": "string",
        "samples": "list of DepthSample",
        "tdr_depths": "check-shot depths",
        "tdr_times": "two-way times"
      }
    },
    "DepthSample": {
      "description": "CANON_9 at single depth",
      "fields": {
        "depth": "m",
        "density": "kg/m³",
        "vp": "m/s",
        "vs": "m/s",
        "resistivity": "Ω·m",
        "magnetic_suscept": "SI",
        "thermal_conduct": "W/(m·K)",
        "pressure": "Pa",
        "temperature": "K",
        "porosity": "fraction",
        "sw": "fraction",
        "salinity": "ppm"
      }
    },
    "SyntheticCMP": {
      "description": "Synthetic common midpoint gather",
      "fields": {
        "traces": "array [n_samples, n_angles]",
        "time": "array [n_samples] in seconds",
        "angles": "array [n_angles] in degrees",
        "wavelet": "Wavelet object"
      }
    }
  },
  
  "telemetry_format": "[GEOX-1D | {stage} | well:{well_id} | misfit:{misfit:.4f} | floors:{floors} | {status}]"
}
