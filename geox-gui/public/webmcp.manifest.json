{
  "$schema": "https://geox.arif-fazil.com/schemas/app-manifest/v1.json",
  "manifest_id": "geox.webmcp.root",
  "version": "2026.04.11",
  "display_name": "GEOX WebMCP Surface Index",
  "description": "Root WebMCP discovery manifest for GEOX mission workspaces deployed on geox.arif-fazil.com.",
  "site": "https://geox.arif-fazil.com/",
  "mcp": {
    "url": "https://geox.arif-fazil.com/mcp/",
    "transport": "streamable-http",
    "requires_accept": "text/event-stream"
  },
  "a2a": {
    "url": "https://geox.arif-fazil.com/a2a/",
    "transport": "http-json"
  },
  "apps": [
    {
      "app_id": "geox.ac_risk.console",
      "manifest_url": "https://geox.arif-fazil.com/ac_risk_console/manifest.json"
    },
    {
      "app_id": "geox.basin.explorer",
      "manifest_url": "https://geox.arif-fazil.com/basin_explorer/manifest.json"
    },
    {
      "app_id": "geox.seismic.viewer",
      "manifest_url": "https://geox.arif-fazil.com/seismic_viewer/manifest.json"
    },
    {
      "app_id": "geox.well.context-desk",
      "manifest_url": "https://geox.arif-fazil.com/well_context_desk/manifest.json"
    }
  ],
  "governance": {
    "manual_gate": "888_HOLD",
    "required_floors": ["F1", "F2", "F4", "F7", "F9", "F11", "F13"]
  }
}
