{
  "$schema": "https://geox.arif-fazil.com/schemas/app-manifest/v1.json",
  "app_id": "geox.ac_risk.console",
  "version": "1.0.0-AAA",
  "domain": "governance",
  "display_name": "AC_Risk Console",
  "description": "Interactive Theory of Anomalous Contrast risk calculator with real-time verdict display",
  "icon": "https://geox.arif-fazil.com/apps/ac_risk_console/icon.svg",
  "required_tools": [
    "mcp.geox.compute_ac_risk"
  ],
  "optional_tools": [
    "mcp.geox.list_tools",
    "mcp.geox.load_seismic_line"
  ],
  "ui_entry": {
    "resource_uri": "https://geox.arif-fazil.com/apps/ac_risk_console/index.html",
    "mode": "inline-or-external",
    "capability_required": [
      "embedded_webview"
    ],
    "csp_policy": "default-src 'self'; script-src 'self' 'unsafe-inline'; connect-src 'self' https://api.geox.arif-fazil.com; style-src 'self' 'unsafe-inline';",
    "sandbox": "allow-scripts allow-same-origin",
    "inline_config": {
      "max_width": 1200,
      "max_height": 900,
      "resize": true
    },
    "external_config": {
      "window_features": "width=1400,height=1000,menubar=no,toolbar=no"
    }
  },
  "auth": {
    "mode": "jwt",
    "token_ttl_seconds": 600,
    "scopes": [
      "tenant:{tenant_id}",
      "role:geoscientist|manager|viewer|admin",
      "governance:read"
    ],
    "refreshable": true
  },
  "events": {
    "supported": [
      "app.initialize",
      "app.context.patch",
      "app.state.sync",
      "tool.request",
      "tool.result",
      "ui.action",
      "ui.state.change",
      "ac_risk.calculated",
      "ac_risk.reset",
      "auth.challenge",
      "auth.result",
      "host.resize",
      "telemetry.emit"
    ],
    "max_payload_size": 524288
  },
  "fallback": {
    "chain": [
      "inline",
      "external",
      "card",
      "text"
    ],
    "external_url": "https://geox.arif-fazil.com/apps/ac_risk_console/?session={session_id}",
    "card_template": "/apps/ac_risk_console/card.html"
  },
  "arifos": {
    "required_floors": [
      "F1",
      "F2",
      "F4",
      "F7",
      "F9",
      "F11",
      "F13"
    ],
    "audit_level": "full",
    "vault_route": "999_VAULT",
    "human_in_the_loop": [
      "export_risk_report",
      "apply_to_production"
    ]
  },
  "meta": {
    "author": "GEOX Platform Team",
    "license": "MIT",
    "repository": "https://github.com/ariffazil/arifos-geox",
    "homepage": "https://geox.arif-fazil.com/apps/ac_risk_console/",
    "keywords": [
      "ac_risk",
      "toac",
      "governance",
      "risk-assessment",
      "constitutional"
    ],
    "created_at": "2026-04-10T00:00:00Z",
    "updated_at": "2026-04-10T00:00:00Z"
  }
}
