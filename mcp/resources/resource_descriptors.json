  "resources": [
    {
      "uri": "physics://elastic/bounds",
      "name": "Elastic Rock Physics Bounds",
      "description": "Vp, Vs, density, and Poisson ratio physical bounds by lithology and fluid substitution. Used for range validation in QC and Physics9 guard.",
      "mimeType": "application/json",
      "version": "v1.0",
      "subscribable": false,
      "update_policy": "static",
      "last_updated": "2026-05-01",
      "source": "Mavko (2023) Rock Physics Handbook",
      "coverage": ["sandstone", "limestone", "dolomite", "shale"],
      "fields": {
        "Vp": {"unit": "m/s", "range_by_lithology": true},
        "Vs": {"unit": "m/s", "range_by_lithology": true},
        "density": {"unit": "g/cc", "range_by_lithology": true},
        "Poisson_ratio": {"unit": "dimensionless", "range": [0.0, 0.5]}
      }
    },
    {
      "uri": "physics://fluid/pvt",
      "name": "Fluid PVT Properties",
      "description": "PVT tables, GOR, API gravity, and Gassmann fluid modulus bounds. Used for fluid substitution in rock physics.",
      "mimeType": "application/json",
      "version": "v1.0",
      "subscribable": false,
      "update_policy": "static",
      "last_updated": "2026-05-01",
