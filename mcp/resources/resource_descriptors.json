      "fields": {
        "API_gravity": {"unit": "API", "range": [10.0, 60.0]},
        "GOR": {"unit": "scf/stb", "range": [0.0, 10000.0]},
        "Bo": {"unit": "rb/stb", "range": [1.0, 2.5]},
        "Bt": {"unit": "rb/stb", "range": [1.0, 3.0]},
        "compressibility_oil": {"unit": "1/psi", "range": [1e-6, 1e-4]},
        "compressibility_water": {"unit": "1/psi", "range": [3e-7, 5e-7]},
        "compressibility_gas": {"unit": "1/psi", "range": [1e-4, 1e-2]}
      }
    },
