{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AssetMemoryRecord",
  "type": "object",
  "required": ["asset_id", "eval_type", "timestamp", "payload", "vault_receipt"],
  "properties": {
    "asset_id": { "type": "string" },
    "eval_type": { "type": "string" },
    "timestamp": { "type": "string", "format": "date-time" },
    "payload": { "type": "object" },
    "vault_receipt": { "type": "string" }
  }
}
